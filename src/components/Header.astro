---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="header">
  <a href={`/${lang === 'es' ? '' : lang}`} class="logo">Rodrigo Rejala</a>
  <div class="controls">
    <button id="lang-toggle" class="control-btn" title="Change language">
      <span class="lang-code">{lang.toUpperCase()}</span>
    </button>
    <button id="theme-toggle" class="control-btn" title="Toggle theme">
      <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="5"/>
        <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
      </svg>
    </button>
  </div>
</header>

<nav class="nav">
  <a href={`/${lang === 'es' ? '' : lang}`}>{t('nav.home')}</a>
  <a href={`/${lang === 'es' ? '' : lang + '/'}blog`}>{t('nav.blog')}</a>
</nav>

<script>
  const langToggle = document.getElementById('lang-toggle');
  const themeToggle = document.getElementById('theme-toggle');
  
  langToggle?.addEventListener('click', () => {
    const currentLang = document.documentElement.lang;
    const langs = ['es', 'en', 'pt'];
    const currentIndex = langs.indexOf(currentLang);
    const nextLang = langs[(currentIndex + 1) % langs.length];
    const path = window.location.pathname;
    
    if (nextLang === 'es') {
      window.location.href = path.replace(/^\/(en|pt)/, '') || '/';
    } else {
      window.location.href = '/' + nextLang + path.replace(/^\/(es|en|pt)/, '').replace(/^\/$/, '');
    }
  });

  themeToggle?.addEventListener('click', () => {
    const html = document.documentElement;
    const current = html.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>

<style>
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space);
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .logo {
    font-weight: 600;
    text-decoration: none;
    font-size: 1.1rem;
  }

  .controls {
    display: flex;
    gap: 0.5rem;
  }

  .control-btn {
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
  }

  .control-btn:hover {
    border-color: var(--text);
  }

  .icon {
    width: 16px;
    height: 16px;
  }

  .lang-code {
    font-weight: 600;
  }

  .nav {
    display: flex;
    gap: 1.5rem;
    padding: 0 var(--space);
    max-width: var(--max-width);
    margin: 0 auto 2rem;
  }

  .nav a {
    text-decoration: none;
    font-size: 0.9rem;
  }

  .nav a:hover {
    text-decoration: underline;
  }
</style>
